exports[`Example composer (end-to-end) honors customClientName param 1`] = `
"import time
from client import MyEchoClient

def handle_handle_time_stamp_message(message):
    print(f\\"[handleTimeStampMessage] Received message: {message}\\")

def custom_error_handler(error):
    print(f\\"WebSocket error: {error}\\")

def outgoing_message_processor(message):
    \\"\\"\\"Process outgoing messages before they are sent (e.g., wrap with metadata).\\"\\"\\"
    print(f\\"Outgoing processor fired: {message}\\")
    return {\\"payload\\": message, \\"timestamp\\": \\"2025-01-01T00:00:00Z\\"}

def main():
    client = MyEchoClient()
    client.register_handle_time_stamp_message_handler(handle_handle_time_stamp_message)
    client.register_error_handler(custom_error_handler)
    client.register_outgoing_processor(outgoing_message_processor)

    try:
        client.connect()
        for i in range(5):
            try:
                client.send_echo_message('test')
            except Exception as e:
                print(f\\"Error while sending send_echo_message: {e}\\")
            time.sleep(2)
        time.sleep(30)  # Increase as needed to keep the connection alive longer
    except Exception as error:
        print(f\\"Failed to connect to WebSocket: {error}\\")
    finally:
        client.close()


if __name__ == '__main__':
    main()"
`;

