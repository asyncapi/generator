exports[`Example composer (end-to-end) renders receive-only example.py for slack (no send loop, with keep-alive) 1`] = `
"import time
from client import SlackWebsocketAPIClient

def handle_on_hello_message(message):
    print(f\\"[onHelloMessage] Received message: {message}\\")

def handle_on_event(message):
    print(f\\"[onEvent] Received message: {message}\\")

def handle_on_disconnect_message(message):
    print(f\\"[onDisconnectMessage] Received message: {message}\\")

def custom_error_handler(error):
    print(f\\"WebSocket error: {error}\\")

def main():
    client = SlackWebsocketAPIClient()
    client.register_on_hello_message_handler(handle_on_hello_message)
    client.register_on_event_handler(handle_on_event)
    client.register_on_disconnect_message_handler(handle_on_disconnect_message)
    client.register_error_handler(custom_error_handler)

    try:
        client.connect()
        time.sleep(30)  # Increase as needed to keep the connection alive longer
    except Exception as error:
        print(f\\"Failed to connect to WebSocket: {error}\\")
    finally:
        client.close()


if __name__ == '__main__':
    main()"
`;
