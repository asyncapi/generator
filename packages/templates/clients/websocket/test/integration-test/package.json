{
    "name": "@asyncapi/template-integration-test",
    "private": true,
    "description": "This is a integration tests for all the websocket clients",
    "scripts": {
        "test": "npm run test:python && npm run test:java-quarkus && npm run test:dart && npm run test:javascript",
        "test:update": "npm run test:python:update && npm run test:java-quarkus:update && npm run test:dart:update && npm run test:javascript:update",
        "test:dart": "cross-env TEST_CLIENT=dart jest",
        "test:python": "cross-env TEST_CLIENT=python jest",
        "test:java-quarkus": "cross-env TEST_CLIENT=java-quarkus jest",
        "test:javascript": "cross-env TEST_CLIENT=javascript jest",
        "test:dart:update": "cross-env TEST_CLIENT=dart jest -u",
        "test:python:update": "cross-env TEST_CLIENT=python jest -u",
        "test:java-quarkus:update": "cross-env TEST_CLIENT=java-quarkus jest -u",
        "test:javascript:update": "cross-env TEST_CLIENT=javascript jest -u",
        "lint": "eslint --max-warnings 0 --config ../../../../../../.eslintrc --ignore-path ../../../../../../.eslintignore .",
        "lint:fix": "eslint --fix --max-warnings 0 --config ../../../../../../.eslintrc --ignore-path ../../../../../../.eslintignore ."
    },
    "author": "Adi Boghawala <boghawalaadi@gmail.com>",
    "license": "Apache-2.0",
    "dependencies": {
        "@asyncapi/generator-helpers": "1.1.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.25.9",
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-react": "^7.25.9",
        "@asyncapi/generator": "*",
        "cross-env": "^7.0.3",
        "eslint": "^6.8.0",
        "eslint-plugin-jest": "^23.8.2",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-sonarjs": "^0.5.0"
    }
}