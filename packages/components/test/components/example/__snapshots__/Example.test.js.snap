"import 'dart:async';
import 'echo_client.dart';

void myMessageHandler(String message) {
  print('====================');
  print('Just proving I got the message in myMessageHandler: $message');
  print('====================');
}

void myErrorHandler(Object error) {
  print('Errors from WebSocket: $error');
}

Future<void> main() async {
  final echoClient = EchoClient();
  echoClient.registerMessageHandler(myMessageHandler);
  echoClient.registerErrorHandler(myErrorHandler);

  try {
    await echoClient.connect();

    for (var i = 0; i < 5; i++) {
      try {
        echoClient.noMessage('TODO: replace with payload for noMessage');
        echoClient.noSummaryOperations('TODO: replace with payload matching noSummaryOperations');
        echoClient.noSummaryNoDescriptionOperations('test');
        echoClient.mixedMessageExamples('TODO: replace with payload matching mixedMessageExamples');
        echoClient.operation_with_snake_case('TODO: replace with payload matching operation_with_snake_case');
      } catch (error) {
        print('Error while sending message: $error');
      }
      await Future.delayed(Duration(seconds: 5));
    }
  } catch (error) {
    print('Failed to connect to WebSocket: $error');
  } finally {
    echoClient.close();
  }
}"
`;

exports[`Testing of Example composer render full example for language = javascript 1`] = `
"const EchoClient = require('./echoClient');

function myMessageHandler(message) {
  console.log('====================');
  console.log('Just proving I got the message in myMessageHandler:', message);
  console.log('====================');
}

function myErrorHandler(error) {
  console.error('Errors from WebSocket:', error.message);
}

function outgoingProcessor(message) {
  const processed = { payload: message, timestamp: new Date().toISOString() };
  console.log('Outgoing processor fired:', JSON.stringify(processed));
  return processed;
}

async function main() {
  const echoClient = new EchoClient();
  echoClient.registerMessageHandler(myMessageHandler);
  echoClient.registerErrorHandler(myErrorHandler);

  echoClient.registerOutgoingProcessor(outgoingProcessor);

  try {
    await echoClient.connect();

    for (let i = 0; i < 5; i++) {
      try {
          await echoClient.noMessage('TODO: replace with payload for noMessage');
          await echoClient.noSummaryOperations('TODO: replace with payload matching noSummaryOperations');
          await echoClient.noSummaryNoDescriptionOperations('test');
          await echoClient.mixedMessageExamples('TODO: replace with payload matching mixedMessageExamples');
          await echoClient.operation_with_snake_case('TODO: replace with payload matching operation_with_snake_case');
      } catch (error) {
        console.error('Error while sending message:', error);
      }
      await new Promise(resolve => setTimeout(resolve, 5000));
    }
  } catch (error) {
    console.error('Failed to connect to WebSocket:', error.message);
  } finally {
    await echoClient.close();
  }
}

main();"
`;

